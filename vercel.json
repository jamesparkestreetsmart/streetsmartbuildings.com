{
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 30
    },
    "app/api/cron/thermostat-enforce/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/manifest-generate/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/send-scheduled-emails",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/thermostat-enforce",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/manifest-generate",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/alert-evaluate",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/deliver-notifications",
      "schedule": "*/2 * * * *"
    }
  ]
}
